{
  "name": "@kvenno/monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Kvennaskólinn Education Platform - Unified Monorepo",
  "author": "Kvennaskólinn",
  "license": "MIT",
  "scripts": {
    "dev:landing": "pnpm --filter @kvenno/landing dev",
    "dev:lab-reports": "pnpm --filter @kvenno/lab-reports dev",
    "dev:islenskubraut": "pnpm --filter @kvenno/islenskubraut dev",
    "dev:games": "pnpm --filter './apps/games/**' dev",
    "build": "node scripts/build-all.mjs",
    "build:landing": "pnpm --filter @kvenno/landing build",
    "build:lab-reports": "pnpm --filter @kvenno/lab-reports build",
    "build:islenskubraut": "pnpm --filter @kvenno/islenskubraut build",
    "build:games": "node scripts/build-games.mjs",
    "build:game": "node scripts/build-games.mjs --game",
    "build:year": "node scripts/build-games.mjs --year",
    "type-check": "pnpm --recursive run type-check",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json}\"",
    "test": "vitest run && pnpm --filter kvenno-server test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check-all": "pnpm type-check && pnpm lint && pnpm format:check",
    "analyze": "node scripts/analyze-bundles.mjs",
    "clean": "pnpm --recursive run clean && rm -rf node_modules dist",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/react": "^16.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "husky": "^9.1.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.1.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,json,md,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {}
}
